{
  // 允许包含 HTML 标签（因为 Quartz 支持 React 组件和 HTML 嵌入）
  "MD033": false,

  // 允许长行，不强制换行（中文内容强制换行容易把排版和段落打断）
  "MD013": false,

  // 允许文件第一行不是最高级标题（因为 Markdown 文件的开头通常是 YAML Frontmatter，即 ---）
  "MD041": false,

  // 允许同名标题存在（比如有多个同级的“背景”或者“总结”标题，不会报错）
  "MD024": { "siblings_only": true },

  // 强制代码块前后必须有空行（就是刚才的 MD031 规则，保持开启）
  "MD031": true,

  // 允许无序列表在不同缩进层级下使用不同的符号（如 -, *, + 混用）
  "MD004": false,
}
